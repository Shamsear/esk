--
-- Name: ensure_player_id(); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.ensure_player_id() RETURNS trigger
    LANGUAGE plpgsql
    AS $$
BEGIN
  -- If ID is NULL or 0, generate a new one
  IF NEW.id IS NULL OR NEW.id = 0 THEN
    NEW.id := get_next_player_id();
    RAISE NOTICE 'Auto-assigned player ID: %', NEW.id;
  END IF;
  
  -- Validate position - ensure it's one of the allowed values
  IF NEW.position IS NULL OR NEW.position NOT IN ('GK', 'CB', 'RB', 'LB', 'DM', 'CM', 'AM', 'LW', 'RW', 'ST') THEN
    RAISE WARNING 'Invalid position % provided. Setting to default position ST', NEW.position;
    NEW.position := 'ST'; -- Default to striker
  END IF;
  
  RETURN NEW;
END;
$$;


ALTER FUNCTION public.ensure_player_id() OWNER TO postgres;

--
-- Name: get_next_player_id(); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.get_next_player_id() RETURNS integer
    LANGUAGE plpgsql
    AS $$
DECLARE
  next_id INTEGER;
BEGIN
  -- Get the maximum ID and add 1
  SELECT COALESCE(MAX(id), 0) + 1 INTO next_id FROM players;
  RETURN next_id;
END;
$$;


ALTER FUNCTION public.get_next_player_id() OWNER TO postgres;

--
-- Name: handle_club_deletion(); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.handle_club_deletion() RETURNS trigger
    LANGUAGE plpgsql
    AS $$
BEGIN
  -- Set club_id to NULL for any players or managers referencing this club
  UPDATE players SET club_id = NULL WHERE club_id = OLD.id;
  UPDATE managers SET club_id = NULL WHERE club_id = OLD.id;
  
  RETURN OLD;
END;
$$;


ALTER FUNCTION public.handle_club_deletion() OWNER TO postgres;

--
-- Name: handle_manager_deletion(); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.handle_manager_deletion() RETURNS trigger
    LANGUAGE plpgsql
    AS $$
DECLARE
  squad_player_record RECORD;
  manager_club_id INTEGER;
  other_managers_with_club INTEGER;
BEGIN
  -- Skip if we're already in a synchronization process
  IF is_sync_in_progress('updating_from_squad') THEN
    RETURN OLD;
  END IF;
  
  -- Get the club ID of the manager being deleted
  manager_club_id := OLD.club_id;
  
  -- Log the manager deletion
  RAISE NOTICE 'Processing deletion of manager ID % (%) with club ID %', 
    OLD.id, OLD.name, manager_club_id;
  
  -- Set flag to avoid recursive triggers
  PERFORM set_sync_flag('updating_from_squad', true);
  
  BEGIN
    -- For each player in the manager's squad
    FOR squad_player_record IN 
      SELECT ms.player_id, p.name AS player_name
      FROM manager_squads ms
      JOIN players p ON ms.player_id = p.id
      WHERE ms.manager_id = OLD.id
    LOOP
      -- Check if this player belongs to squads of other managers
      IF NOT EXISTS (
        SELECT 1
        FROM manager_squads ms2
        WHERE ms2.player_id = squad_player_record.player_id
          AND ms2.manager_id != OLD.id
      ) THEN
        -- Player is only in this manager's squad, make them a free agent
        RAISE NOTICE 'Making player % (%) a free agent', 
          squad_player_record.player_id, squad_player_record.player_name;
          
        UPDATE players
        SET club_id = NULL
        WHERE id = squad_player_record.player_id;
      ELSE
        -- Player is in other squads too, so just log
        RAISE NOTICE 'Player % (%) remains in other squads', 
          squad_player_record.player_id, squad_player_record.player_name;
      END IF;
    END LOOP;
    
    -- Now, check if other managers are using this club
    IF manager_club_id IS NOT NULL THEN
      SELECT COUNT(*) INTO other_managers_with_club
      FROM managers
      WHERE club_id = manager_club_id
        AND id != OLD.id;
        
      -- If this was the only manager using this club, log a warning
      IF other_managers_with_club = 0 THEN
        RAISE WARNING 'Club ID % is now orphaned (no managers assigned)', manager_club_id;
      END IF;
    END IF;
  EXCEPTION
    WHEN OTHERS THEN
      RAISE WARNING 'Error processing manager deletion: % %', SQLERRM, SQLSTATE;
  END;
  
  -- Reset flag
  PERFORM set_sync_flag('updating_from_squad', false);
  
  RETURN OLD;
END;
$$;


ALTER FUNCTION public.handle_manager_deletion() OWNER TO postgres;

--
-- Name: handle_player_club_change(); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.handle_player_club_change() RETURNS trigger
    LANGUAGE plpgsql
    AS $$
DECLARE
  manager_id_var INTEGER;
BEGIN
  -- Only process when club_id changes or when a new player is created with a club
  IF TG_OP = 'INSERT' OR NEW.club_id IS DISTINCT FROM OLD.club_id THEN
    -- Skip if we're in the middle of a squad update
    IF is_sync_in_progress('updating_from_squad') THEN
      RETURN NEW;
    END IF;
    
    -- Set custom setting to indicate we're updating from player
    PERFORM set_sync_flag('updating_from_player', true);
    
    -- If player is assigned to a club
    IF NEW.club_id IS NOT NULL THEN
      -- Get the manager_id associated with this club
      SELECT id INTO manager_id_var FROM managers WHERE club_id = NEW.club_id LIMIT 1;
      
      IF manager_id_var IS NOT NULL THEN
        -- Check if player is already in manager_squads for this manager
        IF NOT EXISTS (
          SELECT 1 FROM manager_squads 
          WHERE player_id = NEW.id AND manager_id = manager_id_var
        ) THEN
          -- Add player to manager_squads if not exists
          INSERT INTO manager_squads (
            manager_id, player_id, player_name, position, value
          ) VALUES (
            manager_id_var, NEW.id, NEW.name, NEW.position, NEW.value
          );
        ELSE
          -- Update existing entry
          UPDATE manager_squads
          SET 
            player_name = NEW.name,
            position = NEW.position,
            value = NEW.value
          WHERE player_id = NEW.id AND manager_id = manager_id_var;
        END IF;
      END IF;
    END IF;
    
    -- If player was moved from one club to another, remove from old manager's squad
    IF TG_OP = 'UPDATE' AND OLD.club_id IS NOT NULL AND OLD.club_id != NEW.club_id THEN
      DELETE FROM manager_squads
      WHERE player_id = NEW.id AND manager_id IN (
        SELECT id FROM managers WHERE club_id = OLD.club_id
      );
    END IF;
    
    -- Reset the setting
    PERFORM set_sync_flag('updating_from_player', false);
  END IF;
  
  RETURN NEW;
END;
$$;


ALTER FUNCTION public.handle_player_club_change() OWNER TO postgres;

--
-- Name: handle_player_transfer(); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.handle_player_transfer() RETURNS trigger
    LANGUAGE plpgsql
    AS $$
DECLARE
  new_club_id INTEGER;
  old_club_id INTEGER;
  player_name_var TEXT;
  current_season INTEGER;
BEGIN
  -- Get the new club ID from the manager
  SELECT club_id, current_season INTO new_club_id, current_season 
  FROM managers 
  WHERE id = NEW.manager_id;
  
  -- Get the player's old club ID and name
  SELECT club_id, name INTO old_club_id, player_name_var
  FROM players
  WHERE id = NEW.player_id;
  
  -- If this is actually a transfer (different clubs)
  IF old_club_id IS DISTINCT FROM new_club_id AND old_club_id IS NOT NULL AND new_club_id IS NOT NULL THEN
    RAISE NOTICE 'Transfer detected for player % (ID: %) from club % to club %',
      player_name_var, NEW.player_id, old_club_id, new_club_id;
      
    -- Get old club name
    DECLARE
      old_club_name TEXT;
      new_club_name TEXT;
    BEGIN
      SELECT name INTO old_club_name 
      FROM clubs 
      WHERE id = old_club_id;
      
      SELECT name INTO new_club_name 
      FROM clubs 
      WHERE id = new_club_id;
      
      -- Create a record in player_stats for the transfer
      -- This allows tracking which seasons a player spent at which club
      INSERT INTO player_stats (
        player_id,
        season,
        team,
        value,
        apps
      ) VALUES (
        NEW.player_id,
        CASE 
          WHEN current_season IS NOT NULL THEN current_season::TEXT
          ELSE 'Transfer'
        END,
        old_club_name || ' → ' || new_club_name,
        NEW.value,
        0
      );
      
      RAISE NOTICE 'Created transfer record for % from % to % in season %',
        player_name_var, old_club_name, new_club_name, current_season;
    END;
  END IF;
  
  RETURN NEW;
END;
$$;


ALTER FUNCTION public.handle_player_transfer() OWNER TO postgres;

--
-- Name: handle_squad_addition(); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.handle_squad_addition() RETURNS trigger
    LANGUAGE plpgsql
    AS $$
DECLARE
  club_id_var INTEGER;
  player_exists BOOLEAN;
  next_player_id INTEGER;
  transaction_successful BOOLEAN := false;
BEGIN
  -- Skip if already in a synchronization process
  IF is_sync_in_progress('updating_from_player') THEN
    RETURN NEW;
  END IF;

  -- Only when a new player is added to a squad
  IF TG_OP = 'INSERT' THEN
    -- Start transaction control - important for complex operations
    BEGIN
      -- Get the club_id from the manager
      SELECT club_id INTO club_id_var FROM managers WHERE id = NEW.manager_id;
      
      -- Check if player exists in players table
      SELECT EXISTS(
        SELECT 1 FROM players WHERE id = NEW.player_id
      ) INTO player_exists;
      
      -- Set custom setting to indicate we're updating from squad
      PERFORM set_sync_flag('updating_from_squad', true);
      
      -- Only proceed if we have a valid player_id
      IF NEW.player_id IS NOT NULL THEN
        IF player_exists THEN
          -- Update the player's club, position and value
          UPDATE players
          SET 
            club_id = club_id_var,
            position = COALESCE(NEW.position, position),
            value = COALESCE(NEW.value, value)
          WHERE id = NEW.player_id;
          
          -- Update player name in manager_squads if necessary
          IF NEW.player_name IS NULL OR NEW.player_name = '' THEN
            UPDATE manager_squads
            SET player_name = (SELECT name FROM players WHERE id = NEW.player_id)
            WHERE id = NEW.id;
          END IF;
        ELSE
          -- Player doesn't exist - create a new player record
          -- First, get the next available player_id if needed
          IF NEW.player_id < 1 THEN
            SELECT COALESCE(MAX(id), 0) + 1 INTO next_player_id FROM players;
          ELSE
            next_player_id := NEW.player_id;
          END IF;
          
          -- Insert new player with proper validation
          INSERT INTO players (
            id, name, position, value, club_id, level, star, games_played
          ) VALUES (
            next_player_id,
            COALESCE(NEW.player_name, 'Player ' || next_player_id),
            COALESCE(NEW.position, 'ST'),
            COALESCE(NEW.value, 1000000),
            club_id_var,
            'STANDARD',
            '3-star-standard',
            0
          );
          
          -- Log that we created a player
          RAISE NOTICE 'Created new player ID % (%) for squad ID %', 
            next_player_id, 
            COALESCE(NEW.player_name, 'Player ' || next_player_id),
            NEW.id;
          
          -- If we had to create a new ID, update the squad record
          IF NEW.player_id != next_player_id THEN
            UPDATE manager_squads
            SET player_id = next_player_id
            WHERE id = NEW.id;
          END IF;
        END IF;
      END IF;
      
      -- Mark transaction as successful
      transaction_successful := true;
      
      -- Reset the setting
      PERFORM set_sync_flag('updating_from_squad', false);
      
    EXCEPTION
      WHEN OTHERS THEN
        -- Log the error
        RAISE WARNING 'Error in handle_squad_addition: % %', SQLERRM, SQLSTATE;
        
        -- Ensure we reset the setting even if there's an error
        IF is_sync_in_progress('updating_from_squad') THEN
          PERFORM set_sync_flag('updating_from_squad', false);
        END IF;
        
        -- Let the error propagate
        RAISE;
    END;
  END IF;
  
  RETURN NEW;
END;
$$;


ALTER FUNCTION public.handle_squad_addition() OWNER TO postgres;

--
-- Name: handle_squad_deletion(); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.handle_squad_deletion() RETURNS trigger
    LANGUAGE plpgsql
    AS $$
DECLARE
  other_squads_count INTEGER;
BEGIN
  -- Skip if already in a synchronization process
  IF is_sync_in_progress('updating_from_squad') THEN
    RETURN OLD;
  END IF;

  -- Only perform this check if we have a valid player_id
  IF OLD.player_id IS NOT NULL THEN
    -- Set custom setting to indicate we're updating from squad
    PERFORM set_sync_flag('updating_from_squad', true);
    
    -- Count how many other squads this player is in
    SELECT COUNT(*) INTO other_squads_count
    FROM manager_squads
    WHERE player_id = OLD.player_id AND id != OLD.id;
    
    -- If this is the player's only squad, set them as a free agent
    IF other_squads_count = 0 THEN
      UPDATE players
      SET club_id = NULL
      WHERE id = OLD.player_id;
    END IF;
    
    -- Reset the setting
    PERFORM set_sync_flag('updating_from_squad', false);
  END IF;
  
  RETURN OLD;
END;
$$;


ALTER FUNCTION public.handle_squad_deletion() OWNER TO postgres;

--
-- Name: is_sync_in_progress(text); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.is_sync_in_progress(flag_name text) RETURNS boolean
    LANGUAGE plpgsql
    AS $$
BEGIN
  RETURN current_setting('app.' || flag_name, true) = 'true';
EXCEPTION
  WHEN undefined_object THEN
    RETURN false;
END;
$$;


ALTER FUNCTION public.is_sync_in_progress(flag_name text) OWNER TO postgres;

--
-- Name: populate_initial_competition_awards(); Type: PROCEDURE; Schema: public; Owner: postgres
--

CREATE PROCEDURE public.populate_initial_competition_awards()
    LANGUAGE plpgsql
    AS $$
DECLARE
  manager_rec RECORD;
BEGIN
  -- For each manager, trigger the award sync function
  FOR manager_rec IN SELECT id FROM managers WHERE awards > 0 LOOP
    -- Update the manager to trigger the award sync
    UPDATE managers
    SET awards = awards
    WHERE id = manager_rec.id;
  END LOOP;
END;
$$;


ALTER PROCEDURE public.populate_initial_competition_awards() OWNER TO postgres;

--
-- Name: protect_squad_players(); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.protect_squad_players() RETURNS trigger
    LANGUAGE plpgsql
    AS $$
DECLARE
  squad_count INTEGER;
  stats_count INTEGER;
  squad_info TEXT;
  stats_info TEXT;
BEGIN
  -- First check if player is in any squads
  WITH squad_details AS (
    SELECT 
      ms.manager_id,
      m.name AS manager_name,
      ms.id AS squad_id
    FROM 
      manager_squads ms
      JOIN managers m ON ms.manager_id = m.id
    WHERE 
      ms.player_id = OLD.id
  )
  SELECT 
    COUNT(*),
    string_agg('Manager: ' || manager_name || ' (Squad ID: ' || squad_id || ')', E'\n')
  INTO 
    squad_count,
    squad_info
  FROM squad_details;
  
  -- Next, check if player has any match statistics
  WITH stats_details AS (
    SELECT 
      ps.id,
      ps.season,
      ps.team
    FROM 
      player_stats ps
    WHERE 
      ps.player_id = OLD.id
  )
  SELECT
    COUNT(*),
    string_agg('Season: ' || season || ', Team: ' || team, E'\n')
  INTO
    stats_count,
    stats_info
  FROM stats_details;
  
  -- If player is in any squads, prevent deletion
  IF squad_count > 0 THEN
    RAISE EXCEPTION 'Cannot delete player ID % (%) as they are in % manager squads: %', 
      OLD.id, OLD.name, squad_count, squad_info;
  END IF;
  
  -- If player has match statistics, prevent deletion even if not in a squad
  IF stats_count > 0 THEN
    RAISE EXCEPTION 'Cannot delete player ID % (%) as they have match statistics in % seasons: %',
      OLD.id, OLD.name, stats_count, stats_info;
  END IF;
  
  RETURN OLD;
END;
$$;


ALTER FUNCTION public.protect_squad_players() OWNER TO postgres;

--
-- Name: reset_all_sync_flags(); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.reset_all_sync_flags() RETURNS void
    LANGUAGE plpgsql
    AS $$
BEGIN
  PERFORM set_sync_flag('updating_from_player', false);
  PERFORM set_sync_flag('updating_from_squad', false);
  PERFORM set_sync_flag('updating_club_total', false);
EXCEPTION
  WHEN OTHERS THEN
    RAISE WARNING 'Error resetting sync flags: % %', SQLERRM, SQLSTATE;
END;
$$;


ALTER FUNCTION public.reset_all_sync_flags() OWNER TO postgres;

--
-- Name: resolve_player_club_conflicts(); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.resolve_player_club_conflicts() RETURNS trigger
    LANGUAGE plpgsql
    AS $$
DECLARE
  old_club_id INTEGER;
  new_club_id INTEGER;
  squad_count INTEGER;
  conflict_clubs TEXT;
  conflict_managers TEXT;
BEGIN
  -- Skip if already in a synchronization process
  IF is_sync_in_progress('updating_from_player') OR
     is_sync_in_progress('updating_from_squad') THEN
    RETURN NEW;
  END IF;
  
  -- Only proceed if club_id is changing
  IF TG_OP = 'UPDATE' AND OLD.club_id IS DISTINCT FROM NEW.club_id THEN
    old_club_id := OLD.club_id;
    new_club_id := NEW.club_id;
    
    -- Check if player is in multiple squads
    WITH manager_clubs AS (
      SELECT 
        ms.manager_id,
        m.name AS manager_name,
        m.club_id,
        c.name AS club_name
      FROM 
        manager_squads ms
        JOIN managers m ON ms.manager_id = m.id
        LEFT JOIN clubs c ON m.club_id = c.id
      WHERE 
        ms.player_id = NEW.id
        AND m.club_id IS NOT NULL
        AND m.club_id != new_club_id
    )
    SELECT 
      COUNT(*), 
      string_agg(DISTINCT club_name, ', '),
      string_agg(DISTINCT manager_name, ', ')
    INTO 
      squad_count, 
      conflict_clubs,
      conflict_managers
    FROM manager_clubs;
    
    -- If player is in multiple squads with different clubs, log a warning
    IF squad_count > 0 THEN
      RAISE WARNING 'Player ID % (%) is being moved to a new club but is also in squads of managers (%) with clubs (%)',
        NEW.id, NEW.name, conflict_managers, conflict_clubs;
    END IF;
  END IF;
  
  RETURN NEW;
END;
$$;


ALTER FUNCTION public.resolve_player_club_conflicts() OWNER TO postgres;

--
-- Name: set_sync_flag(text, boolean); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.set_sync_flag(flag_name text, value boolean) RETURNS void
    LANGUAGE plpgsql
    AS $$
BEGIN
  PERFORM set_config('app.' || flag_name, 
                    CASE WHEN value THEN 'true' ELSE 'false' END,
                    true);
EXCEPTION
  WHEN insufficient_privilege THEN
    RAISE WARNING 'Unable to set flag %: insufficient privileges', flag_name;
END;
$$;


ALTER FUNCTION public.set_sync_flag(flag_name text, value boolean) OWNER TO postgres;

--
-- Name: sync_club_changes(); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.sync_club_changes() RETURNS trigger
    LANGUAGE plpgsql
    AS $$
BEGIN
  -- Update all players that reference this club
  UPDATE players
  SET club_id = NEW.id
  WHERE club_id = OLD.id;
  
  -- Update all managers that reference this club
  UPDATE managers
  SET club_id = NEW.id
  WHERE club_id = OLD.id;
  
  RETURN NEW;
END;
$$;


ALTER FUNCTION public.sync_club_changes() OWNER TO postgres;

--
-- Name: sync_manager_club_to_players(); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.sync_manager_club_to_players() RETURNS trigger
    LANGUAGE plpgsql
    AS $$
BEGIN
  -- If manager's club has changed, update all players in their squad
  IF OLD.club_id IS DISTINCT FROM NEW.club_id THEN
    -- Get all player IDs from manager_squads
    UPDATE players
    SET club_id = NEW.club_id
    WHERE id IN (
      SELECT player_id 
      FROM manager_squads 
      WHERE manager_id = NEW.id
    );
  END IF;
  
  RETURN NEW;
END;
$$;


ALTER FUNCTION public.sync_manager_club_to_players() OWNER TO postgres;

--
-- Name: sync_manager_club_to_squad(); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.sync_manager_club_to_squad() RETURNS trigger
    LANGUAGE plpgsql
    AS $$
BEGIN
  -- If manager's club changes, we might need to update their squad players' clubs
  IF NEW.club_id IS DISTINCT FROM OLD.club_id THEN
    -- Update all players in this manager's squad to the new club
    UPDATE players
    SET club_id = NEW.club_id
    WHERE id IN (
      SELECT player_id 
      FROM manager_squads 
      WHERE manager_id = NEW.id AND player_id IS NOT NULL
    );
  END IF;
  
  RETURN NEW;
END;
$$;


ALTER FUNCTION public.sync_manager_club_to_squad() OWNER TO postgres;

--
-- Name: sync_new_squad_to_player(); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.sync_new_squad_to_player() RETURNS trigger
    LANGUAGE plpgsql
    AS $$
DECLARE
  club_id_var INTEGER;
BEGIN
  -- Get the club_id from the manager
  SELECT club_id INTO club_id_var FROM managers WHERE id = NEW.manager_id;
  
  -- Only update if we have a valid player_id and club_id
  IF NEW.player_id IS NOT NULL AND club_id_var IS NOT NULL THEN
    -- Update the player's club and value
    UPDATE players
    SET 
      club_id = club_id_var,
      value = NEW.value
    WHERE id = NEW.player_id;
  END IF;
  
  RETURN NEW;
END;
$$;


ALTER FUNCTION public.sync_new_squad_to_player() OWNER TO postgres;

--
-- Name: sync_player_name_to_squad(); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.sync_player_name_to_squad() RETURNS trigger
    LANGUAGE plpgsql
    AS $$
BEGIN
  -- If player name changes, update it in manager_squads
  IF NEW.name != OLD.name THEN
    UPDATE manager_squads
    SET player_name = NEW.name
    WHERE player_id = NEW.id;
  END IF;
  
  RETURN NEW;
END;
$$;


ALTER FUNCTION public.sync_player_name_to_squad() OWNER TO postgres;

--
-- Name: sync_player_to_squad(); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.sync_player_to_squad() RETURNS trigger
    LANGUAGE plpgsql
    AS $$
BEGIN
  -- Prevent recursive trigger loops - only update if values have actually changed
  IF (NEW.name IS DISTINCT FROM OLD.name OR 
      NEW.position IS DISTINCT FROM OLD.position OR 
      NEW.value IS DISTINCT FROM OLD.value) THEN
      
    -- Check if this update was triggered by the squad update function
    IF is_sync_in_progress('updating_from_squad') THEN
      -- Skip updating manager_squads if we're in the middle of processing a squad update
      RETURN NEW;
    END IF;
    
    -- Set custom setting to indicate we're updating from player
    PERFORM set_sync_flag('updating_from_player', true);
    
    BEGIN
      -- Update all manager_squads entries that reference this player
      UPDATE manager_squads
      SET 
        player_name = NEW.name,
        position = NEW.position,
        value = NEW.value
      WHERE player_id = NEW.id;
    
    EXCEPTION
      WHEN OTHERS THEN
        -- Log error and ensure flag is reset
        RAISE WARNING 'Error in sync_player_to_squad: % %', SQLERRM, SQLSTATE;
    END;
    
    -- Reset the setting
    PERFORM set_sync_flag('updating_from_player', false);
  END IF;
  
  RETURN NEW;
END;
$$;


ALTER FUNCTION public.sync_player_to_squad() OWNER TO postgres;

--
-- Name: sync_squad_delete_to_player(); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.sync_squad_delete_to_player() RETURNS trigger
    LANGUAGE plpgsql
    AS $$
BEGIN
  -- When a player is removed from a squad, set their club to null if this was their only squad
  IF OLD.player_id IS NOT NULL THEN
    IF NOT EXISTS (
      SELECT 1 FROM manager_squads 
      WHERE player_id = OLD.player_id AND id != OLD.id
    ) THEN
      -- This was the player's only squad, set club to NULL (FREE AGENT)
      UPDATE players
      SET club_id = NULL
      WHERE id = OLD.player_id;
    END IF;
  END IF;
  
  RETURN OLD;
END;
$$;


ALTER FUNCTION public.sync_squad_delete_to_player() OWNER TO postgres;

--
-- Name: sync_squad_name_to_player(); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.sync_squad_name_to_player() RETURNS trigger
    LANGUAGE plpgsql
    AS $$
BEGIN
  -- Skip if we're in an update cycle
  IF is_sync_in_progress('updating_from_player') THEN
    RETURN NEW;
  END IF;

  -- Only proceed if player name has changed
  IF NEW.player_name IS DISTINCT FROM OLD.player_name AND NEW.player_id IS NOT NULL THEN
    -- Set flag to prevent recursive updates
    PERFORM set_sync_flag('updating_from_squad', true);
    
    -- Update player name in players table
    -- Check if other squads are using this player with the old name
    IF NOT EXISTS (
      SELECT 1 FROM manager_squads 
      WHERE player_id = NEW.player_id 
      AND id != NEW.id 
      AND player_name != NEW.player_name
    ) THEN
      UPDATE players
      SET name = NEW.player_name
      WHERE id = NEW.player_id;
    END IF;
    
    -- Reset flag
    PERFORM set_sync_flag('updating_from_squad', false);
  END IF;
  
  RETURN NEW;
END;
$$;


ALTER FUNCTION public.sync_squad_name_to_player() OWNER TO postgres;

--
-- Name: sync_squad_to_player(); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.sync_squad_to_player() RETURNS trigger
    LANGUAGE plpgsql
    AS $$
DECLARE
  club_id_var INTEGER;
BEGIN
  -- Check if this update was triggered by the player update function
  IF is_sync_in_progress('updating_from_player') THEN
    -- Skip updating players if we're in the middle of processing a player update
    RETURN NEW;
  END IF;

  -- Only proceed if values have actually changed or if it's a new insert
  IF TG_OP = 'INSERT' OR 
     NEW.position IS DISTINCT FROM OLD.position OR 
     NEW.value IS DISTINCT FROM OLD.value THEN
    
    -- Get the club_id from the manager
    SELECT club_id INTO club_id_var FROM managers WHERE id = NEW.manager_id;
    
    -- Set custom setting to indicate we're updating from squad
    PERFORM set_sync_flag('updating_from_squad', true);
    
    -- Only update if we have a valid player_id
    IF NEW.player_id IS NOT NULL THEN
      -- Update the player's club and value
      UPDATE players
      SET 
        club_id = club_id_var,
        position = NEW.position,
        value = NEW.value
      WHERE id = NEW.player_id;
    END IF;
    
    -- Reset the setting
    PERFORM set_sync_flag('updating_from_squad', false);
  END IF;
  
  RETURN NEW;
END;
$$;


ALTER FUNCTION public.sync_squad_to_player() OWNER TO postgres;

--
-- Name: trigger_manager_rating_update(); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.trigger_manager_rating_update() RETURNS trigger
    LANGUAGE plpgsql
    AS $$
DECLARE
  manager_id_var INTEGER;
BEGIN
  -- Determine manager_id based on trigger context
  IF TG_TABLE_NAME = 'manager_squads' THEN
    manager_id_var := NEW.manager_id;
  ELSIF TG_TABLE_NAME = 'manager_performances' THEN
    manager_id_var := NEW.manager_id;
  ELSIF TG_TABLE_NAME = 'managers' THEN
    -- Only update if trophies changed significantly
    IF NEW.trophies IS DISTINCT FROM OLD.trophies AND ABS(NEW.trophies - OLD.trophies) >= 1 THEN
      manager_id_var := NEW.id;
    ELSE
      RETURN NEW;
    END IF;
  ELSE
    RETURN NEW; -- Exit if we can't determine manager_id
  END IF;
  
  -- Call the rating calculation function
  PERFORM calculate_manager_rating(manager_id_var);
  
  RETURN NEW;
END;
$$;


ALTER FUNCTION public.trigger_manager_rating_update() OWNER TO postgres;

--
-- Name: update_all_manager_ratings(); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.update_all_manager_ratings() RETURNS void
    LANGUAGE plpgsql
    AS $$
DECLARE
  manager_rec RECORD;
BEGIN
  FOR manager_rec IN SELECT id FROM managers LOOP
    PERFORM calculate_manager_rating(manager_rec.id);
  END LOOP;
END;
$$;


ALTER FUNCTION public.update_all_manager_ratings() OWNER TO postgres;

